# =============================================================================
# PhishNet - AI Phishing Detection System
# Environment Configuration
# =============================================================================

# Application
APP_NAME=phishnet
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
SECRET_KEY=change-me-to-a-random-string-in-production
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://phishnet:phishnet_pass@localhost:5432/phishnet
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# JWT Auth
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ML Models
MODEL_DIR=./models
BERT_MODEL_NAME=bert-base-uncased
BERT_MAX_LENGTH=128
ML_CONFIDENCE_THRESHOLD=0.7
ENSEMBLE_WEIGHTS_RF=0.3
ENSEMBLE_WEIGHTS_GB=0.3
ENSEMBLE_WEIGHTS_BERT=0.4

# Feature Extraction
WHOIS_TIMEOUT=10
DNS_TIMEOUT=5
CONTENT_FETCH_TIMEOUT=15
MAX_REDIRECTS=5

# Threat Intelligence
THREATINTEL_API_KEY=
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_KEY=
PHISHTANK_API_KEY=

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/phishnet.log

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Email (SMTP for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@phishnet.io
